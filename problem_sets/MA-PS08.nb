Cell[TextData[{
 "What you want to do is take the range of x values that you found in 1(a). \
We want to know the x range on this plot that keeps ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "4"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "72e433d6-ee26-4eb7-bcdc-370038074573"],
 " within the range you found  in 1(a). Do that with a straight edge. "
}], "Text",
 CellChangeTimes->{{3.829738619177335*^9, 3.829738711065216*^9}, {
  3.8297388697450867`*^9, 3.829738893874873*^9}, {3.829739057121896*^9, 
