Notebook[{

Cell[CellGroupData[{
Cell["Mathematical Analysis Problem Set 8 ", "Chapter",
 CellChangeTimes->{{3.8297409657170067`*^9, 
  3.829740997891358*^9}},ExpressionUUID->"08dff64c-4584-4a30-a4b1-\
c0485c5ee0f5"],

Cell["\<\
Problems For Thursday, May 13, 2021 \[LongDash] the reading is to finish \
Chapter 6\
\>", "Subtitle",
 CellChangeTimes->{{3.829741017397872*^9, 3.8297410327204447`*^9}, {
  3.829741904724494*^9, 
  3.829741922228442*^9}},ExpressionUUID->"9a2c62ca-d9d6-4a5c-b2ab-\
ef4b477dcef9"],

Cell[CellGroupData[{

Cell["Limits and Composition of Functions", "Section",
 CellChangeTimes->{{3.829738920437018*^9, 
  3.829738931300631*^9}},ExpressionUUID->"7e855a0b-1ec0-4961-8f77-\
75be052ffa9b"],

Cell[CellGroupData[{

Cell["1(a)", "Subsection",
 CellChangeTimes->{{3.8297390093669977`*^9, 
  3.829739010367674*^9}},ExpressionUUID->"2b0ddca6-7bc2-4c50-8028-\
cca96911bdcb"],

Cell[TextData[{
 "Hopefully, you vaguely remember this handout from before the break. We are \
trying to gain intuition about how limits work when functions are composed, \
in this case ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", 
    RowBox[{"g", "(", "x", ")"}], ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f76881a4-eedc-476f-a734-24e7480d141c"],
 " at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "2"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6b1b660c-e287-4f67-9d11-6b215b4e901d"],
 ". Below, I have changed the function slightly from the last handout (made \
it sin(\[Pi] x) instead of sin(x)), and also blown up the region from x=15 to \
x=17."
}], "Text",
 CellChangeTimes->{{3.829737938718643*^9, 3.829737950878636*^9}, {
  3.829738030314198*^9, 3.829738209907251*^9}, {3.8297382532303047`*^9, 
  3.829738254242917*^9}, {3.829738946861884*^9, 3.8297389572571287`*^9}, {
  3.829742779881722*^9, 
  3.829742780150837*^9}},ExpressionUUID->"a779fc9a-4c05-4a1c-8819-\
f941891ed9f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"Sin", "[", 
   RowBox[{"Pi", " ", "x"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.828446836051866*^9, 3.828446853612052*^9}, {
  3.82844689299811*^9, 3.828446893020533*^9}, {3.82973773205835*^9, 
  3.829737733677593*^9}, {3.829738420618259*^9, 3.829738420740909*^9}, {
  3.829738455513959*^9, 3.829738458495412*^9}},
 CellLabel->
  "In[122]:=",ExpressionUUID->"f3cdc321-d8cc-4e10-9d10-29c3a7cc6a2f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "15", ",", " ", "17"}], "}"}], ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"15", ",", " ", "17"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", " ", "1"}], "}"}]}], "}"}]}], ",", " ", 
   RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
   RowBox[{"AspectRatio", "\[Rule]", "1.0"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8278415080019093`*^9, 3.827841630901546*^9}, {
   3.82784166434762*^9, 3.8278416670582657`*^9}, {3.827841727055015*^9, 
