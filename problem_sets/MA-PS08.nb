  3.829740790094561*^9}},ExpressionUUID->"e20ac38d-3b89-48c3-a992-\
81be087df4fe"],

Cell[CellGroupData[{

Cell["(i)-(vi)", "Subsection",
 CellChangeTimes->{{3.8297390093669977`*^9, 3.829739030122375*^9}, {
  3.829739483355031*^9, 3.829739484073804*^9}, {3.829739875335593*^9, 
  3.829739876628518*^9}, {3.82974064788583*^9, 3.8297406755487843`*^9}, {
  3.829740779430676*^9, 3.8297407879823303`*^9}, {3.829740898363331*^9, 
  3.829740899072113*^9}},ExpressionUUID->"3787b123-7034-4ab9-a382-\
7e9ee065eb37"],

Cell["\<\
I don't like to burden you guys with too much work, but we really have to \
hammer this in until it is just obvious what to do every time you encounter \
one of these, so do all six parts. If there is one thing to take away from \
this entire course, and that will put you in good stead when you hit \
calculus, it is proving limits for whatever miscellaneous functions you \
encounter.\
\>", "Text",
 CellChangeTimes->{{3.8297400078035603`*^9, 3.8297400324646177`*^9}, {
  3.829740091165308*^9, 3.829740098274469*^9}, {3.829740201144607*^9, 
  3.829740257403676*^9}, {3.8297407493364553`*^9, 3.829740768382538*^9}, {
  3.829740806778288*^9, 
  3.8297408886320753`*^9}},ExpressionUUID->"b7c2f5e4-59a5-4741-b847-\
b971f5f7d3a4"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"b9e1f2e9-f691-48dc-a84e-fbad18d466e4"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Good Elementary Proofs for in-class on Thursday", "Section",
 CellChangeTimes->{{3.828447303125578*^9, 3.8284473071759043`*^9}, {
   3.828448098636496*^9, 3.828448109391552*^9}, 3.828448210755623*^9, {
