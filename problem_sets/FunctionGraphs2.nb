 PageBreakBelow->True,ExpressionUUID->"2bb055bc-d5ac-49ba-a134-c49fa72af446"],

Cell[CellGroupData[{

Cell["Good Practice Problems for Problem 6", "Section",
 CellChangeTimes->{{3.828447303125578*^9, 3.8284473071759043`*^9}, {
  3.828448098636496*^9, 
  3.828448099934167*^9}},ExpressionUUID->"1ea6098e-59d5-41b5-9864-\
a837c8cf4fa2"],

Cell["\<\
If you didn\[CloseCurlyQuote]t find Problem 6 on the exam easy (that would be \
everybody), you should probably re-do all parts of Problem 3 of Spivak \
Chapter 5.

Here are a couple of other problems that use the same techniques as Problem \
6....

For both of these, first, what is the limit? Second, for \[Epsilon] > 0,  \
what is the \[Delta] that keeps the function within \[Epsilon] of the limit.\
\>", "Text",
 CellChangeTimes->{{3.8284474725875397`*^9, 3.828447589824294*^9}, {
  3.828447670769052*^9, 3.82844769501711*^9}, {3.828447786409136*^9, 
  3.828447884611442*^9}},ExpressionUUID->"6a403a4e-861b-40c1-b883-\
5350466f7108"],

Cell[CellGroupData[{

Cell[BoxData[
 FormBox[
  TemplateBox[{
    FractionBox["1", 
     SuperscriptBox["x", "3"]], "x", "1"},
   "Limit2Arg",
   DisplayFunction->(RowBox[{
      TagBox[
       UnderscriptBox[
        StyleBox["\"lim\"", ShowStringCharacters -> False], 
        RowBox[{#2, "\[Rule]", #3}], LimitsPositioning -> True], Identity, 
       SyntaxForm -> "\[Limit]", Tooltip -> "Limit"], #}]& ),
   InterpretationFunction->(RowBox[{"Limit", "[", 
      RowBox[{#, ",", 
        RowBox[{#2, "->", #3}]}], "]"}]& )], TraditionalForm]], "Input",
 CellChangeTimes->{{3.828447600501935*^9, 3.828447682234026*^9}, {
  3.8284477752718554`*^9, 3.828447782605606*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"dc216803-7396-4c5f-a4bf-7f197a50545c"],

Cell[BoxData["1"], "Output",
 CellChangeTimes->{3.828448259606318*^9},
 CellLabel->"Out[62]=",ExpressionUUID->"5af6e0a5-6759-46e5-9833-cb39c372e3f2"]
}, Open  ]],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"With", " ", "a"}], "\[NotEqual]", "0"}], ",", 
   TemplateBox[{
     FractionBox["1", 
      SuperscriptBox["x", "2"]], "x", "a"},
    "Limit2Arg",
    DisplayFunction->(RowBox[{
       TagBox[
        UnderscriptBox[
         StyleBox["\"lim\"", ShowStringCharacters -> False], 
         RowBox[{#2, "\[Rule]", #3}], LimitsPositioning -> True], Identity, 
        SyntaxForm -> "\[Limit]", Tooltip -> "Limit"], #}]& ),
    InterpretationFunction->(RowBox[{"Limit", "[", 
       RowBox[{#, ",", 
         RowBox[{#2, "->", #3}]}], "]"}]& )]}], TraditionalForm]], "Input",
 CellChangeTimes->{{3.828447600501935*^9, 3.828447716153287*^9}, {
  3.828447760862433*^9, 3.8284477677215242`*^9}},
 EmphasizeSyntaxErrors->True,
 CellLabel->"In[63]:=",ExpressionUUID->"01463f5a-c799-4c4d-921b-d17cea99a8c3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Good Practice Problem for Problem 7", "Section",
 CellChangeTimes->{{3.828447303125578*^9, 3.8284473071759043`*^9}, {
