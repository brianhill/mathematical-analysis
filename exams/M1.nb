Cell[TextData[{
 "Check your formula for \[Delta], by evaluating it with \[Epsilon] = 2. What \
is \[Delta]? Is ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox["1", 
     SuperscriptBox["x", "2"]],
    FontSize->16], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "325b1ccb-2fff-4549-bcf3-8b0f429bd34f"],
 " within \[Epsilon] of 1 if x is within \[Delta] of 1?"
}], "Text",
 CellChangeTimes->{{3.828285045936631*^9, 
  3.8282851099845448`*^9}},ExpressionUUID->"bfd0275a-0291-465f-ad16-\
804238b02f06"],

