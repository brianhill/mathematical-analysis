  FormBox[
   RowBox[{"a", "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "687a0f82-ed0c-4c7e-ac3e-8f8e5bcc72fa"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"l", "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "355349ab-b23b-4f3c-969b-c6b2648090e6"],
 " (5 pts)"
}], "Section",
 CellChangeTimes->{{3.728655217903658*^9, 3.728655221681748*^9}, {
   3.7286562999576*^9, 3.728656300056612*^9}, {3.7286564267117853`*^9, 
   3.728656433381549*^9}, {3.728656481104312*^9, 3.7286564858177967`*^9}, {
   3.728817748332402*^9, 3.728817750931053*^9}, 3.728819818765243*^9, {
   3.760222605247715*^9, 3.76022261584509*^9}, {3.760228462934093*^9, 
   3.760228463011297*^9}, {3.826966804614043*^9, 3.826966804691877*^9}, {
   3.826967804301498*^9, 3.826967805673533*^9}, {3.828042848268873*^9, 
   3.828042856491458*^9}, {3.828043219866584*^9, 3.828043226121743*^9}, {
   3.828048650877139*^9, 3.828048654678523*^9}, {3.828264015020916*^9, 
   3.8282640259127493`*^9}, {3.828265232772002*^9, 3.828265239881291*^9}, {
