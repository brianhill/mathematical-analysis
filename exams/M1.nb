Cell[TextData[{
 "The problem is to find a ",
 Cell[BoxData[
  FormBox["\[Delta]", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f9fe7763-d37b-49e7-b257-081c504782ad"],
 " > 0 such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      StyleBox[
       FractionBox["1", 
        SuperscriptBox["x", "2"]],
       FontSize->24], "-", "1"}], "\[RightBracketingBar]"}], "<", 
    "\[Epsilon]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "259dba72-6ebc-4981-a576-e662ba8265be"],
 "."
}], "Text",
 CellChangeTimes->{{3.8282830892635717`*^9, 3.828283097817279*^9}, {
  3.8282832023951263`*^9, 3.8282832065017548`*^9}, {3.828283239361771*^9, 
  3.828283244412677*^9}},ExpressionUUID->"585d07a8-b2d6-480b-a57f-\
b7b3e4f0701c"],

