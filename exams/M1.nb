Cell[TextData[{
 "6. Limit of ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox["1", 
     SuperscriptBox["x", "2"]],
    FontSize->36], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9c37572c-311e-4cf7-bf7d-e1ecaabe50ba"],
