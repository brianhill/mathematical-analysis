Cell[TextData[{
 "HINT 1: Start off by re-writing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{
     StyleBox[
      FractionBox["1", 
       SuperscriptBox["x", "2"]],
      FontSize->24], "-", "1"}], "\[RightBracketingBar]"}], TraditionalForm]],
  ExpressionUUID->"e547b4e7-acb8-42b0-aed6-2b829bc6836e"],
 " as ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox[
     RowBox[{
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"x", "+", "1"}], "\[RightBracketingBar]"}], 
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"x", "-", "1"}], "\[RightBracketingBar]"}]}], 
     RowBox[{"\[LeftBracketingBar]", 
      SuperscriptBox["x", "2"], "\[RightBracketingBar]"}]],
    FontSize->24], TraditionalForm]],ExpressionUUID->
  "b2d464c7-a8db-4d82-ae7d-6a1ccf034bb5"],
 ".\nHINT 2: You now have three factors. Next get bounds on the factors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"x", "+", "1"}], "\[RightBracketingBar]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f6f72db4-bdd0-414a-b5fe-a08f6b8d7def"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox["1", 
     RowBox[{"\[LeftBracketingBar]", 
      StyleBox[
       SuperscriptBox["x", "2"],
       FontSize->14], "\[RightBracketingBar]"}]],
    FontSize->18], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c33bc20c-fa0e-4880-85e3-222e7f61ae79"],
 " by demanding  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"x", "-", "1"}], "\[RightBracketingBar]"}], "<", 
    FractionBox["1", "2"]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "934c1a75-a5c7-457a-b3ec-22a13b4d1ff3"],
 ". So this is going to be one of those problems where in the end ",
 Cell[BoxData[
  FormBox["\[Delta]", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3cbfbe49-6a9e-4d00-b589-e020972cae15"],
 " is the min of ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "2"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9b815af1-99db-47df-bdfe-4e1d7ddac2b2"],
 " and something else involving \[Epsilon].\n\n",
 StyleBox["The whole next page is blank so that you have space to work.",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.828267183935553*^9, 3.828267227730996*^9}, {
   3.828267262067759*^9, 3.828267280235651*^9}, {3.8282673157861834`*^9, 
   3.8282675553892307`*^9}, {3.828267616915555*^9, 3.8282677414194508`*^9}, {
