Cell["2. Induction (3 pts)", "Section",
 CellChangeTimes->{{3.728655217903658*^9, 3.728655221681748*^9}, {
   3.7286562999576*^9, 3.728656300056612*^9}, {3.7286564267117853`*^9, 
