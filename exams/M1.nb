Cell[TextData[{
 "In the following, you can use P1 to P9 freely and without citing which ones \
you are using. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", " ", ">", " ", "b"}], TraditionalForm]],ExpressionUUID->
  "18efca35-0a07-40ab-8ffa-a9b3e943f39c"],
 " ",
 StyleBox["by definition",
  FontWeight->"Bold"],
 " means that  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "-", "b"}], TraditionalForm]],ExpressionUUID->
  "81757bb9-ef6c-45f6-810d-d2d61281f9cb"],
 " is in ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "fb5781f3-d264-4d4d-9c03-c1374a06cb4b"],
 ", where ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "84da78c5-003b-4d7d-a645-64a9ee7d6a27"],
