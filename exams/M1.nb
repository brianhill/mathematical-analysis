0nl7+/XrJ5wXlVPON61pgfMzs3wPp8UKUS103ovHpw0Q/cZpHNjexo0b5a1x
aoJDP63A41gzOMmyuVANPSXsI5kdJNg0GuwDrB1TBjmNw1byNK5swXESWkzS
uwz2U2isEbInrPMaDQEGx4fIhF2gva76oOmQA64CnZ5TzRXEf+SE+F++Bdfj
dEv/YwGqCfA0uFL/WODBvyV4/mV76k8nCtb4\
\>", "ImageResolution" -> 72.],ExpressionUUID->
  "5d622a25-72b6-4969-a381-2348e60cf434"],
 "\nThe graph is showing that (0, 0) is where the two lines meet, that (1, m) \
is a point on the graph of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "bd301465-2aa6-494e-9d38-311650b8cfc7"],
 ", and that (1, n) is a point on the graph of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "cc7d62b3-3f7b-4464-970c-7e77f9a87b9c"],
 ".\n\nClearly, the vertical line has length ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{"m", "-", "n"}], "\[RightBracketingBar]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "a9ea5caa-36c4-4e86-b140-a881ce4c550d"],
 ".\n\n(a) What is the length of each of the two sloped lines?\n\n\n\n\n(b) \
You now have the lengths of each of three sides of a triangle. Write down the \
condition (but do not solve it) that the triangle is a right triangle (e.g., \
write down what the Pythagorean theorem says if this triangle is a right \
triangle).\n\n\n\n\n(c) Now solve the condition you found in part (b) to get \
a pleasantly simple equation involving ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "993e9b9d-a761-494c-a327-a018b699a2f9"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "a74e9a17-e660-4460-ba08-ad377f7adef7"],
 ". Joyfully, you have derived the condition that two lines are \
perpendicular!\n\n\n"
}], "Text",
 CellChangeTimes->{{3.8282654567123213`*^9, 3.828265704693302*^9}, {
   3.828265743505229*^9, 3.828265992363676*^9}, {3.828269759036318*^9, 
   3.8282697592159147`*^9}, {3.828269918269431*^9, 3.828269918616679*^9}, {
   3.82827181001457*^9, 3.828271824323924*^9}, {3.8282824852109003`*^9, 
   3.82828253349401*^9}, {3.828283937094986*^9, 3.8282839670072527`*^9}, {
   3.8282840212086563`*^9, 3.8282840219171457`*^9}, 
   3.828284332230125*^9},ExpressionUUID->"90f3c852-869b-400f-9bb4-\
48b42d035b40"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"d8ad23ee-ada6-4d27-87ef-643875207434"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. The Limits Poem (2 pts)", "Section",
 CellChangeTimes->{{3.728655217903658*^9, 3.728655221681748*^9}, {
   3.7286562999576*^9, 3.728656300056612*^9}, {3.7286564267117853`*^9, 
   3.728656433381549*^9}, {3.728656481104312*^9, 3.7286564858177967`*^9}, {
   3.728817748332402*^9, 3.728817750931053*^9}, 3.728819818765243*^9, {
   3.760222605247715*^9, 3.76022261584509*^9}, {3.760228462934093*^9, 
   3.760228463011297*^9}, {3.826966804614043*^9, 3.826966804691877*^9}, {
   3.826967804301498*^9, 3.826967805673533*^9}, {3.828042848268873*^9, 
   3.828042856491458*^9}, {3.828043219866584*^9, 3.828043226121743*^9}, {
   3.828048650877139*^9, 3.828048654678523*^9}, {3.828264015020916*^9, 
   3.8282640259127493`*^9}, {3.828265232772002*^9, 3.828265239881291*^9}, {
   3.828266030275601*^9, 3.828266033459009*^9}, {3.828269308159217*^9, 
   3.828269308214849*^9}, {3.8282700090447483`*^9, 3.828270018572919*^9}, {
   3.828283799757021*^9, 3.828283799869235*^9}, {3.828284602039432*^9, 
   3.8282846021291924`*^9}, {3.82828472014981*^9, 
   3.828284720217156*^9}},ExpressionUUID->"ad472979-309d-47a2-aaff-\
d70725790d74"],

Cell[TextData[{
 "Definition: we say that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "4eb49b3f-61f4-47f4-bd70-cd851b1d18b8"],
 " has a limit of ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "88bb3567-4ca9-4318-999b-f34c8868c000"],
 " at ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "dcb7ab82-722b-46c1-be5c-ad6d354312a7"],
 " and write"
}], "Text",
 CellChangeTimes->{{3.828266050232862*^9, 3.828266232932494*^9}, {
   3.8282663501120787`*^9, 3.828266359032503*^9}, {3.8282663939754972`*^9, 
   3.828266395773406*^9}, {3.828266544454571*^9, 3.828266547772613*^9}, 
   3.828269351381323*^9},ExpressionUUID->"4978973b-7217-4a21-ab76-\
02f10d1b4d37"],

Cell[BoxData[
 FormBox[
  TemplateBox[{
    RowBox[{
      RowBox[{"f", "(", "x", ")"}], "=", "l"}], "x", "a"},
   "Limit2Arg",
   DisplayFunction->(RowBox[{
      TagBox[
       UnderscriptBox[
        StyleBox["\"lim\"", ShowStringCharacters -> False], 
        RowBox[{#2, "\[Rule]", #3}], LimitsPositioning -> True], Identity, 
       SyntaxForm -> "\[Limit]", Tooltip -> "Limit"], #}]& ),
   InterpretationFunction->(RowBox[{"Limit", "[", 
      RowBox[{#, ",", 
        RowBox[{#2, "->", #3}]}], "]"}]& )], TraditionalForm]], "Input",
 CellChangeTimes->{{3.828266290636858*^9, 
  3.8282663327299833`*^9}},ExpressionUUID->"df7b5348-378a-4886-84da-\
d697a53fada7"],

Cell[TextData[{
 "if and only if\n\n(a) For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Epsilon]", ">", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "75779fbc-7970-46e0-8f4c-ab0c048b6f51"],
 " there exists a \[Delta] > 0 such that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"x", "-", "a"}], "\[RightBracketingBar]"}], "<", "\[Delta]"}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "55ba5914-dec4-46d2-9a00-899b746ac3f6"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "-", "l"}], "\[RightBracketingBar]"}], 
    "<", "\[Epsilon]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "a012b132-f779-4578-a4a4-d4b16505d4b1"],
 ".\n(b) For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Epsilon]", ">", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "b4f2f01f-1e8b-4659-86a2-a11ad4031ef1"],
 " there exists a \[Delta] > 0 such that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"x", "-", "a"}], "\[RightBracketingBar]"}], "<", "\[Delta]"}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "bc9325fc-2052-4cbb-aa8b-620d8b4168f4"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "-", "l"}], "\[RightBracketingBar]"}], 
    "<", "\[Epsilon]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "4987f180-43f5-4940-ba33-d79d62c50e21"],
 ".\n(c) For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Epsilon]", ">", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "35530d50-965c-4073-9085-1a12d018c734"],
 " there exists a \[Delta] > 0 such that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"x", "-", "a"}], "\[RightBracketingBar]"}], "<", "\[Delta]"}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c9df0172-5127-4e15-bd99-3051cd2185e5"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "-", "l"}], "\[RightBracketingBar]"}], 
    "<", "\[Epsilon]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6b47612a-26c9-4dc7-b4d0-d0860e53ddc8"],
 ".\n(d) For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Epsilon]", ">", "0"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "b9eff87f-6891-4ee1-a690-b3f06bd8c07e"],
 " there exists a \[Delta] > 0 such that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"x", "-", "a"}], "\[RightBracketingBar]"}], "<", "\[Delta]"}], 
   TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f2408ed7-6e9b-4a51-98a3-0762368a6d5b"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "-", "l"}], "\[RightBracketingBar]"}], 
    "<", "\[Epsilon]"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "02b558e6-34af-44a4-a16e-8e69f611aaef"],
 ".\n\n",
 StyleBox["Cross out the three wrong definitions.",
  FontSlant->"Italic"]
}], "Text",
 CellChangeTimes->{{3.8282663693717823`*^9, 3.828266527265152*^9}, {
  3.828266560946513*^9, 3.828266682097581*^9}, {3.828270255532906*^9, 
  3.8282702570168467`*^9}, {3.8282703033155823`*^9, 
  3.8282703103640223`*^9}},ExpressionUUID->"fd06b8c6-8c97-4e93-9f2f-\
0e271327efc1"],

Cell["", "PageBreak",
 PageBreakBelow->True,ExpressionUUID->"d3204878-2b28-4d78-a109-dfeee79289e2"]
}, Open  ]],

