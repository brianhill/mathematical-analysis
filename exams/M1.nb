Cell[TextData[{
 "Prove that if the limit as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Rule]", "a"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "8864ee8e-2f3d-4427-b65e-3be73fa71e63"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "d4606f8b-74a5-4527-9247-2dd5dc8595c3"],
 " exists and is ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "287b7de1-7f13-4dcc-9923-044b042d056d"],
 ", then it is also true that the limit as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Rule]", 
    RowBox[{"2", "a"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "1470b7c8-b8a8-4af8-b5b9-5bfd8f6ccbba"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", 
    RowBox[{"x", "/", "2"}], ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "ae99a327-86df-4d16-ae72-3ad780c8e6fc"],
 " exists and is ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "83334024-2b3e-4005-b240-eaa27f022803"],
 "."
}], "Text",
 CellChangeTimes->{{3.828268854217546*^9, 3.8282689668756*^9}, {
