   3.828285249457794*^9}},ExpressionUUID->"a73a029b-6c2b-43f6-8e38-\
30c894ba3c0f"],

Cell["\<\
You are going to show that this formula is always true, by induction:\
\>", "Text",
 CellChangeTimes->{{3.7287860095062723`*^9, 3.728786078883757*^9}, {
   3.728786123850498*^9, 3.7287861717645273`*^9}, {3.728786953501112*^9, 
   3.728786953701021*^9}, {3.7602226889257917`*^9, 3.760222857732997*^9}, 
   3.760266027526678*^9, {3.8269668229944773`*^9, 3.8269668582636414`*^9}, {
   3.828043660350676*^9, 
   3.82804367328833*^9}},ExpressionUUID->"a9ed75a0-e246-4182-af32-\
08545f187f87"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"k", "=", "1"}], "n"], 
    SuperscriptBox["k", "2"]}], "=", 
   RowBox[{
    FractionBox["1", "6"], " ", "n", " ", 
    RowBox[{"(", 
     RowBox[{"n", "+", "1"}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "n"}], "+", "1"}], ")"}]}]}], 
  TraditionalForm]], "Input",
 CellChangeTimes->{3.8282822621388817`*^9, 
  3.82828229421731*^9},ExpressionUUID->"29bf7ef3-4dc7-48b5-8bb7-4e70c7a7ba57"],

Cell[TextData[{
 "\n(a) First check that it is true if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "b2db12a3-4b8a-46c5-9de8-96c01c0fda5f"],
 ":\n\n\n\n(b) Now show that if you assume it is true for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "l"}], TraditionalForm]],ExpressionUUID->
  "42b598d8-9574-4372-a59c-68e98076f5e1"],
 " then it is true for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", 
    RowBox[{"l", "+", "1"}]}], TraditionalForm]],ExpressionUUID->
  "756098b2-1816-4b04-8216-5291b10fa0a6"],
 ".\n\n"
}], "Text",
 CellChangeTimes->{{3.7287860095062723`*^9, 3.728786078883757*^9}, {
   3.728786123850498*^9, 3.7287861717645273`*^9}, {3.728786953501112*^9, 
