       "], "RGB", "XYZ"], Interleaving -> 
     True, MetaInformation -> Association["XMP" -> Association[]]],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{502., 71.},
   PlotRange->{{0, 502.}, {0, 71.}}]], "Input",ExpressionUUID->
  "6795ca7f-c4ee-45ee-8a13-3714156a8ff2"],
 "\n\nFor two functions ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "bbb53513-f902-44c6-93db-a43f20e5a90a"],
 " and ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "8408469e-2ec0-498b-bd48-0f06d794e49b"],
 ", consider the four cases: (i) ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "0a74c2ab-e500-43fa-9495-2e2bcb3d2471"],
 " even, ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "5653ea88-68ed-4dfb-8ea7-1595cd189e1d"],
 " even; (ii)  ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "f5dc2dc1-8603-4cf3-99a4-8a3a269ad57d"],
 " even, ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "9b80d002-8781-4626-887d-ea1237c36b2a"],
 " odd; (iii) ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3ba53d6e-97e1-427c-a971-3e6daff5420b"],
 " odd, ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "cb7acbbd-2ee7-4712-890d-a9bc6a1c6e77"],
 " even; (iv) ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "da5b74ae-301b-45a7-9799-d1f232172f3c"],
 " odd, ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "50e4b07b-4fa1-4993-b193-a801dd2adae6"],
 " odd.  For each of the four cases, determine whether the composition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "\[SmallCircle]", "g"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "755cfaf4-a587-431f-8351-75b8738cc8b2"],
 " is even, odd, or maybe not necessarily either. You may assume that the \
domain of both functions is all of the real numbers.\n\nFor each case, you \
will be starting off with what ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"-", "x"}], ")"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "334e459a-b03b-4e5a-ac3d-c66b4016e0cf"],
 " means.\n\nHINT: If you are uncertain what that means, you might need to \
remind yourself what ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "ce2a5d70-f1e7-4254-b140-4cb786a94e09"],
 " means.\n\n(i) EVEN EVEN CASE    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"-", "x"}], ")"}]}], "="}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "84fe03c9-5252-4e88-87e9-0b232158ce35"],
 "\n\n\n\n(ii) EVEN ODD CASE     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"-", "x"}], ")"}]}], "="}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "5c3d66c5-1c8a-42f9-b1c6-1684350a33d9"],
 "\n\n\n\n (iii) ODD EVEN CASE   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"-", "x"}], ")"}]}], "="}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "80de9fea-950a-4d6b-aa93-54efd14ccc53"],
 "\n\n\n\n(iv) ODD ODD CASE      ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "\[SmallCircle]", "g"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"-", "x"}], ")"}]}], "="}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "e74ccd88-cf14-4f03-963d-bf2c29e92fe9"],
 "\n\n\n\n\n\n\n\n"
}], "Text",
 CellChangeTimes->{{3.828264645158432*^9, 3.828265179143841*^9}, {
  3.828268664352901*^9, 3.828268665680097*^9}, {3.8282696892412977`*^9, 
  3.8282697538723173`*^9}, {3.8282712323657627`*^9, 3.8282716532565203`*^9}, {
  3.8282832909878073`*^9, 3.828283347848145*^9}, {3.828284325789454*^9, 
