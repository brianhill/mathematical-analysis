    RowBox[{"x", "\[Equal]", "0"}], ",", " ", "1", ",", " ", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Abs", "[", "x", "]"}], 
      RowBox[{"2", "/", "3"}]], "+", 
     RowBox[{
      RowBox[{"Sign", "[", "x", "]"}], 
      SuperscriptBox[
       RowBox[{"Abs", "[", "x", "]"}], 
       RowBox[{"1", "/", "3"}]]}], "+", "1"}]}], "]"}]}]], "Input",
