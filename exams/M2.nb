c1f4d1778627"],

Cell[TextData[{
 "Use the definition of the limit \[LongDash] a \[Delta]\[Dash]\[Epsilon] \
proof starting with the limits poem \[LongDash] to show that:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["lim", 
      RowBox[{"x", " ", "\[Rule]", "\[VeryThinSpace] ", "1"}]], " ", 
     SuperscriptBox["x", 
      RowBox[{"1", "/", "3"}]]}], "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontSize->18,ExpressionUUID->"9d7cfbe5-e190-4631-a96b-7e43e57800c7"],
 "\nHINT: After writing down what you are trying to prove, multiply ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", 
     RowBox[{"1", "/", "3"}]], "-", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "d4d7deb6-c3f4-4b7a-9d11-c1e42c412598"],
 " by ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox[
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"2", "/", "3"}]], "+", 
      SuperscriptBox["x", 
       RowBox[{"1", "/", "3"}]], "+", "1"}], 
     RowBox[{
      SuperscriptBox["x", 
       RowBox[{"2", "/", "3"}]], "+", 
      SuperscriptBox["x", 
       RowBox[{"1", "/", "3"}]], "+", "1"}]],
    FontSize->18], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontSize->24,ExpressionUUID->"2154bc95-4eb9-474c-9f88-b950e98fbd5c"],
 " and simplify."
}], "Text",
 CellChangeTimes->{{3.7283836009935427`*^9, 3.728383602769161*^9}, {
