  FormatType->"TraditionalForm",ExpressionUUID->
  "78ab937d-0663-497e-a542-bf6c68608473"],
 ". Draw ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3fa32605-406c-4b44-b9ed-725da817727f"],
 ". Do your drawings suggest that a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "84caae0c-11d5-4012-a53f-f97b164d2d4d"],
 " that is related to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "7cbd13dc-d5f0-4fca-b1b6-5e99cb295c31"],
 " to which you can apply Theorem 1, and thereby prove Theorem 4? ",
 StyleBox["Your drawings aren\[CloseCurlyQuote]t the proof.",
  FontSlant->"Italic"],
 " Your drawings are just to help you realize what ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "x", ")"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6ef62bd7-4c58-41c8-91aa-a90ab431945b"],
 " you need to consider."
}], "Text",
 CellChangeTimes->{{3.8329304920891657`*^9, 3.832930643325972*^9}, {
   3.832930675895062*^9, 3.832930735419894*^9}, {3.832930778936466*^9, 
   3.832930788464074*^9}, {3.8329310500770082`*^9, 3.832931149238742*^9}, {
   3.8329311955926113`*^9, 3.832931203770492*^9}, {3.832931388419093*^9, 
   3.83293148543931*^9}, {3.832931528934811*^9, 3.832931537245812*^9}, {
   3.83293334091073*^9, 3.83293336322882*^9}, 3.832935528433605*^9, {
   3.832935568518117*^9, 
   3.8329355822533617`*^9}},ExpressionUUID->"45a41dcd-beb9-4205-b2b5-\
5f92fd4624b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Derivatives (5 pts)", "Section",
 CellChangeTimes->{{3.728655217903658*^9, 3.728655221681748*^9}, {
   3.7286562999576*^9, 3.728656300056612*^9}, {3.7286564267117853`*^9, 
   3.728656433381549*^9}, {3.728656481104312*^9, 3.7286564858177967`*^9}, {
   3.728817748332402*^9, 3.728817750931053*^9}, 3.728819818765243*^9, {
   3.760222605247715*^9, 3.76022261584509*^9}, {3.760228462934093*^9, 
   3.760228463011297*^9}, {3.826966804614043*^9, 3.826966804691877*^9}, {
   3.826967804301498*^9, 3.826967805673533*^9}, {3.828042848268873*^9, 
   3.828042856491458*^9}, {3.828043219866584*^9, 3.828043226121743*^9}, {
   3.828048650877139*^9, 3.828048654678523*^9}, {3.828264015020916*^9, 
   3.8282640259127493`*^9}, {3.828265232772002*^9, 3.828265239881291*^9}, {
   3.828270003858506*^9, 3.828270005500348*^9}, {3.8282833649223537`*^9, 
   3.828283365462504*^9}, {3.8282845988902693`*^9, 3.8282845990133944`*^9}, {
   3.8329315569101753`*^9, 3.832931558811078*^9}, {3.8329316146797647`*^9, 
   3.832931614757987*^9}, {3.832932544690401*^9, 
   3.83293254477039*^9}},ExpressionUUID->"20acceaa-0c2d-43a3-8cd8-\
0e0407ebfe5f"],

Cell[TextData[{
 "You have found (using the binomial theorem), that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    SuperscriptBox["x", "n"]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "5c480ced-97ed-4791-a7f7-80a7adbdbe9d"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"f", "'"}], 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{"n", "\[VeryThinSpace]", 
     SuperscriptBox["x", 
      RowBox[{"n", "-", "1"}]]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "0b74fcae-cbda-4ef3-91b2-53475dd8f6da"],
 ". Surprisingly, even though you only proved this using the binomial theorem \
for integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "fc443159-5eaf-4bdd-b0e7-4816eddd4802"],
 ", it is true for all real ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "3215bed7-6339-4324-b2ec-5b3e6b956ca4"],
 ": if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    SuperscriptBox["x", "\[Alpha]"]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "e4bfb769-b3b4-46db-a42f-ca36f1a64c1f"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"f", "'"}], 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{"\[Alpha]", "\[VeryThinSpace]", 
     SuperscriptBox["x", 
      RowBox[{"\[Alpha]", "-", "1"}]]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "e255757c-c6ea-4bc6-ae53-b4da3a5fc6ff"],
 ".\n\n(i) Plug ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"1", "/", "3"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "bd6958a2-d649-4084-ba60-16e1057a7804"],
 " into this formula to get the derivative of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", 
    RowBox[{"1", "/", "3"}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "80c18e87-a6e1-458f-be76-7fc4bfe87c3d"],
 ". (ii) Evaluate what you got in (i) for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "1"}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "239c21d0-6923-4f13-81ff-7edff5a6db39"],
 ". (iii) Now that you have an answer, show that your answer to (ii) is \
correct starting from the definition of the derivative:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     RowBox[{
      RowBox[{"f", "'"}], 
      RowBox[{"(", "1", ")"}]}],
     FontSize->16], 
    StyleBox["\[Congruent]",
     FontSize->16], " ", 
    RowBox[{
     SubscriptBox[
      StyleBox["lim",
       FontSize->16], 
      RowBox[{"h", " ", "\[Rule]", "\[VeryThinSpace] ", "0"}]], 
     FractionBox[
      RowBox[{" ", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "+", "h"}], ")"}], 
         RowBox[{"1", "/", "3"}]], "-", "1"}]}], "h"]}]}], TraditionalForm]],
  FormatType->"TraditionalForm",
  FontSize->18,ExpressionUUID->"f7f253c1-8943-44d7-ba63-d9dd0813f5f0"],
 "\nHINT: Very much like Problem 1, multiply through by ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", "h"}], ")"}], 
       RowBox[{"2", "/", "3"}]], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", "h"}], ")"}], 
       RowBox[{"1", "/", "3"}]], "+", "1"}], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", "h"}], ")"}], 
       RowBox[{"2", "/", "3"}]], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", "h"}], ")"}], 
       RowBox[{"1", "/", "3"}]], "+", "1"}]],
    FontSize->18], TraditionalForm]],
  FontSize->24,ExpressionUUID->"e1946d4f-1a6a-4526-b5cc-fab94e1bfb7e"],
 ". Also, you can use any formulas for simplifying limits (like the limit of \
the sum is the sum of the limits)."
}], "Text",
 CellChangeTimes->{{3.832931841379867*^9, 3.832932213523014*^9}, {
  3.832932277584889*^9, 3.8329325197283373`*^9}, {3.832932654696883*^9, 
  3.832932793795931*^9}, {3.832932825596177*^9, 3.8329328325374002`*^9}, {
  3.8329328643995733`*^9, 3.8329328743313437`*^9}, {3.83293327610752*^9, 
  3.832933276421522*^9}, {3.832933387485485*^9, 3.8329334859233303`*^9}, {
  3.832933653001192*^9, 3.832933673631772*^9}, {3.832935511458395*^9, 
  3.832935511604136*^9}},ExpressionUUID->"510acc8c-babb-43b4-b5e3-\
ef9b5df6c68a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Complex Numbers (3 pts)", "Section",
 CellChangeTimes->{{3.728655217903658*^9, 3.728655221681748*^9}, {
   3.7286562999576*^9, 3.728656300056612*^9}, {3.7286564267117853`*^9, 
   3.728656433381549*^9}, {3.728656481104312*^9, 3.7286564858177967`*^9}, {
   3.728817748332402*^9, 3.728817750931053*^9}, 3.728819818765243*^9, {
   3.760222605247715*^9, 3.76022261584509*^9}, {3.760228462934093*^9, 
   3.760228463011297*^9}, {3.826966804614043*^9, 3.826966804691877*^9}, {
   3.826967804301498*^9, 3.826967805673533*^9}, {3.828042848268873*^9, 
   3.828042856491458*^9}, {3.828043219866584*^9, 3.828043226121743*^9}, {
   3.828048650877139*^9, 3.828048654678523*^9}, {3.828264015020916*^9, 
   3.8282640259127493`*^9}, {3.828265232772002*^9, 3.828265239881291*^9}, {
   3.828266030275601*^9, 3.828266033459009*^9}, {3.828269308159217*^9, 
   3.828269308214849*^9}, {3.8282700090447483`*^9, 3.828270018572919*^9}, {
   3.828283799757021*^9, 3.828283799869235*^9}, {3.828284602039432*^9, 
   3.8282846021291924`*^9}, {3.82828472014981*^9, 3.828284720217156*^9}, {
   3.832931619606423*^9, 3.8329316283481913`*^9}, {3.832932609470006*^9, 
   3.832932612046138*^9}},ExpressionUUID->"ad472979-309d-47a2-aaff-\
d70725790d74"],

Cell[TextData[{
 "Write ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{"3", " ", "+", " ", 
     RowBox[{"4", "i"}]}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "1857ef0e-d645-4abc-99ec-b2b228f08e4a"],
 " in the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", " ", "+", 
    RowBox[{"b", "\[VeryThinSpace]", "i"}]}], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "73a924d4-0812-4841-b85b-767e7168bf23"],
 ".\n\nHINT: Start with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox[
     RowBox[{"3", " ", "+", " ", 
      RowBox[{"4", "i"}]}]], "=", 
    RowBox[{"a", "+", 
     RowBox[{"b", "\[VeryThinSpace]", "i"}]}]}], TraditionalForm]],
  ExpressionUUID->"5c657d5b-4cd2-4ba4-84ed-830fb47d5e12"],
 " and square both sides. Then solve for ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "c771aed3-6daf-49d2-b623-96da610ae4d4"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "21069500-ae79-4f1e-ae6a-72df4a5e2d8b"],
 ". There are two solutions."
}], "Text",
 CellChangeTimes->{{3.8282663693717823`*^9, 3.828266527265152*^9}, {
  3.828266560946513*^9, 3.828266682097581*^9}, {3.828270255532906*^9, 
  3.8282702570168467`*^9}, {3.8282703033155823`*^9, 3.8282703103640223`*^9}, {
  3.8329331577560263`*^9, 3.83293326319271*^9}, {3.832933496442986*^9, 
  3.832933514457007*^9}},ExpressionUUID->"fd06b8c6-8c97-4e93-9f2f-\
0e271327efc1"]
}, Open  ]]
}, Open  ]]
},
